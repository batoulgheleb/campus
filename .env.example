# Environment variables for Student Swap
# Copy this to .env and fill in your values

# Database (PostgreSQL) - uses port 5433 to avoid conflict with local Postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/studentswap

# Redis (sessions/cache)
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Stripe (leave empty for now)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PLATFORM_FEE_PERCENT=4

# AWS S3 (leave empty for now)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=studentswap-images
S3_REGION=eu-west-2

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
